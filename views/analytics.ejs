<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shortify Analytics</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            padding: 30px;
            background: linear-gradient(135deg, #0f172a, #1e293b, #312e81);
            color: white;
            position: relative;
        }

        /* Background Glow */
        body::before,
        body::after {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            filter: blur(100px);
            z-index: 0;
        }

        body::before {
            background: #3b82f6;
            top: -100px;
            left: -100px;
        }

        body::after {
            background: #8b5cf6;
            bottom: -100px;
            right: -100px;
        }

        /* Container */
        .container {
            width: 1000px;
            margin: auto;
            position: relative;
            z-index: 1;
        }

        /* Back Button */
        .back-btn {
            display: inline-block;
            margin-bottom: 25px;
            padding: 12px 20px;
            border-radius: 12px;
            text-decoration: none;
            color: white;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            transition: .3s;
        }

        .back-btn:hover {
            transform: translateY(-2px);
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 35px;
        }

        .logo {
            width: 80px;
            height: 80px;
            margin: auto;
            margin-bottom: 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 20px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            font-size: 2rem;
            box-shadow: 0 10px 25px rgba(59, 130, 246, .4);
        }

        .header h1 {
            margin-bottom: 10px;
        }

        .header p {
            color: #94a3b8;
        }

        /* Stats */
        .stats {
            display: flex;
            gap: 20px;
            margin-bottom: 25px;
        }

        .card {
            flex: 1;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, .25);
        }

        .card h3 {
            color: #94a3b8;
            margin-bottom: 10px;
        }

        .value {
            font-size: 1.8rem;
            font-weight: 700;
        }

        /* URL Card */
        .url-card {
            margin-bottom: 25px;
        }

        .url-card p {
            color: #e2e8f0;
            word-break: break-all;
            margin-top: 10px;
        }

        /* Table */
        .table-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, .25);
        }

        .table-card h2 {
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            padding: 15px;
            color: #60a5fa;
            border-bottom: 1px solid rgba(255, 255, 255, .15);
        }

        td {
            padding: 15px;
            border-bottom: 1px solid rgba(255, 255, 255, .08);
        }

        tr:hover {
            background: rgba(255, 255, 255, .04);
        }

        .empty {
            text-align: center;
            color: #94a3b8;
            padding: 30px;
        }

        /* Footer */
        .footer {
            margin-top: 25px;
            text-align: center;
            color: #94a3b8;
        }
    </style>
</head>

<body>
    <div class="container"> <a href="/" class="back-btn"> ← Back to Home </a>
        <div class="header">
            <div class="logo"> 🔗 </div>
            <h1>Shortify Analytics</h1>
            <p> Detailed statistics for your shortened URL </p>
        </div>
        <div class="stats">
            <div class="card">
                <h3>Short ID</h3>
                <div class="value">
                    <%= shortId %>
                </div>
            </div>
            <div class="card">
                <h3>Total Clicks</h3>
                <div class="value">
                    <%= totalClicks %>
                </div>
            </div>
        </div>
        <div class="card url-card">
            <h3>Original URL</h3>
            <p>
                <%= redirectURL %>
            </p>
        </div>
        <div class="table-card">
            <h2>Visit History</h2>
            <% if(analytics.length===0){ %>
                <div class="empty"> No clicks recorded yet. </div>
                <% } else { %>
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Timestamp</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% analytics.forEach((visit,index)=> { %> <tr>
                                    <td>
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <%= visit.timestamp %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                    <% } %>
        </div>
        <div class="footer"> Built with Node.js • Express.js • MongoDB • EJS </div>
    </div>
</body>

</html>