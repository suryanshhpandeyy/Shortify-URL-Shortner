<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shortify Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #0f172a, #1e293b, #312e81);
            overflow: hidden;
            position: relative;
        }

        /* Animated Background */
        body::before,
        body::after {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            filter: blur(120px);
            animation: float 8s infinite ease-in-out;
        }

        body::before {
            background: #3b82f6;
            top: -100px;
            left: -100px;
        }

        body::after {
            background: #8b5cf6;
            bottom: -100px;
            right: -100px;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(30px);
            }
        }

        /* Card */
        .container {
            width: 100%;
            max-width: 450px;
            padding: 20px;
            z-index: 10;
        }

        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, .4);
        }

        /* Logo */
        .logo {
            width: 75px;
            height: 75px;
            margin: auto;
            margin-bottom: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 20px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            font-size: 2rem;
        }

        /* Text */
        h1 {
            color: white;
            text-align: center;
            margin-bottom: 10px;
        }

        .subtitle {
            text-align: center;
            color: #cbd5e1;
            margin-bottom: 30px;
            line-height: 1.5;
        }

        /* Inputs */
        .form-group {
            margin-bottom: 18px;
        }

        label {
            color: #e2e8f0;
            display: block;
            margin-bottom: 8px;
            font-size: .95rem;
        }

        input {
            width: 100%;
            padding: 15px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, .15);
            background: rgba(255, 255, 255, .08);
            color: white;
            outline: none;
            transition: .3s;
        }

        input::placeholder {
            color: #94a3b8;
        }

        input:focus {
            border-color: #60a5fa;
            box-shadow: 0 0 0 4px rgba(96, 165, 250, .15);
        }

        /* Password */
        .password-wrapper {
            position: relative;
        }

        .password-wrapper span {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #cbd5e1;
        }

        /* Button */
        button {
            width: 100%;
            padding: 15px;
            margin-top: 10px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            color: white;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: .3s;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(59, 130, 246, .4);
        }

        /* Footer */
        .footer {
            text-align: center;
            margin-top: 25px;
            color: #cbd5e1;
        }

        .footer a {
            color: #60a5fa;
            text-decoration: none;
            font-weight: 600;
        }

        .footer a:hover {
            text-decoration: underline;
        }

        /* Error */
        .error {
            background: rgba(239, 68, 68, .15);
            color: #fca5a5;
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 20px;
            text-align: center;
        }

        /* Responsive */
        @media(max-width:500px) {
            .card {
                padding: 30px 25px;
            }

            h1 {
                font-size: 1.8rem;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="card">
            <div class="logo"> 🔗 </div>
            <h1>Welcome Back</h1>
            <p class="subtitle"> Login to continue managing your shortened links. </p>
            <% if(typeof error !=='undefined' && error) { %>
                <div class="error">
                    <%= error %>
                </div>
                <% } %>
                    <form action="/login" method="POST">
                        <div class="form-group"> <label>Email Address</label> <input type="email" name="Email"
                                placeholder="XYZ@example.com" required> </div>
                        <div class="form-group"> <label>Password</label>
                            <div class="password-wrapper"> <input type="password" id="password" name="Password"
                                    placeholder="Enter your password" required> <span id="togglePassword"> 👁️ </span>
                            </div>
                        </div> <button type="submit"> Continue → </button>
                    </form>
                    <div class="footer"> Don't have an account? <a href="/signup">Create Account</a> </div>
        </div>
    </div>
    <script> const password = document.getElementById("password"); const togglePassword = document.getElementById("togglePassword"); togglePassword.addEventListener("click", () => { if (password.type === "password") { password.type = "text"; togglePassword.textContent = "🙈"; } else { password.type = "password"; togglePassword.textContent = "👁️"; } }); </script>
</body>

</html>